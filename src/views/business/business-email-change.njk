{% extends 'common/layout.njk' %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "common/navigation/back-sign-out-link.njk" import appBackSignOutLink with context %}

{% block beforeContent %}
  {{ appBackSignOutLink(backLink)}}
{% endblock %}

{% block content %}
  {% if errors %}
    {{ govukErrorSummary({
        titleText: "There is a problem",
        errorList: errors | toErrorList
    }) }}
  {% endif %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <form method="post" novalidate>
      <input type="hidden" name="crumb" value="{{ crumb }}">
      {{ govukInput({
        label: {
          text: pageTitle,
          classes: "govuk-label--l",
          isPageHeading: true
        },
        classes: "govuk-input--width-20",
        id: "businessEmail",
        name: "businessEmail",
        type: "email",
        autocomplete: "email",
        spellcheck: false,
        value: businessEmail,
        errorMessage: errors.businessEmail and {
          text: errors.businessEmail.text
        }
      }) }}

      {{ govukButton({ text: "Continue", preventDoubleClick: true }) }}
    </form>
  </div>
</div>
{% endblock %}
