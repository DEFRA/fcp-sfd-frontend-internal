{% extends 'common/layout.njk' %}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "common/navigation/breadcrumbs-sign-out-link.njk" import appBreadcrumbsSignOutLink with context %}

{% block beforeContent %}
  {{ appBreadcrumbsSignOutLink({ breadcrumbs: breadcrumbs }) }}
{% endblock %}

{% block content %}
<div class="govuk-main-wrapper">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl govuk-!-margin-bottom-3">
        <span class="govuk-caption-l">Single business identifier (SBI): {{ sbi }}</span>
        {{ businessName }}
      </h1>

      <h2 class="govuk-heading-m govuk-!-margin-top-5">Business details</h2>
      <p class="govuk-body">
        <a href="#" class="govuk-link govuk-link--no-visited-state">View and update business details</a>
      </p>
    </div>
  </div>

  <div class="govuk-grid-row govuk-!-margin-top-5">
    <div class="govuk-grid-column-two-thirds">
      {% if hasCustomers %}
        {% set customerRows = [] %}
        {% for customer in customers %}
          {% set nameHtml %}<a href="/customer/{{ customer.crn }}" class="govuk-link govuk-link--no-visited-state">{{ customer.fullName }}</a>{% endset %}
          {% set customerRows = (customerRows.push([
            { html: nameHtml },
            { text: customer.crn }
          ]), customerRows) %}
        {% endfor %}

        {{ govukTable({
          caption: "Customers linked to this business",
          captionClasses: "govuk-table__caption--m",
          firstCellIsHeader: true,
          head: [
            { text: "Customer name" },
            { text: "Customer reference number (CRN)" }
          ],
          rows: customerRows
        }) }}

        {% if pagination.numberOfPages > 1 %}
          <div class="govuk-grid-row govuk-!-margin-top-9">
            <div class="govuk-grid-column-full">
              {{ govukPagination(pagination.component) }}
            </div>
          </div>

          <p class="govuk-body">Showing <b>{{ pagination.startItem }}</b> to <b>{{ pagination.endItem }}</b> of <b>{{ pagination.paginationTotal }}</b> customers</p>
        {% endif %}
      {% else %}
        <p class="govuk-body">There are no registered customers.</p>
      {% endif %}
    </div>
  </div>
</div>

{% endblock %}
