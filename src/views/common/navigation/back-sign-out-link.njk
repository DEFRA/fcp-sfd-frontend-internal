{% macro appBackSignOutLink(params = {}) %}
  {% from "govuk/components/back-link/macro.njk" import govukBackLink %}

  <div class="govuk-grid-row sub-header-container govuk-!-padding-top-3">
    {% if params.backLink %}
      <div class="govuk-grid-column-two-thirds">
        {{ govukBackLink({
          text: params.text | default("Back"),
          href: params.href | default("/"),
          classes: "govuk-!-margin-top-0"
        }) }}
      </div>
    {% endif %}

    {% if auth.isAuthenticated %}
      <div class="govuk-grid-column-{% if params.backLink %}one-third{% else %}full{% endif %} govuk-!-text-align-right">
        <a href="/auth/sign-out" class="govuk-link govuk-link--no-visited-state">Sign out</a>
      </div>
    {% endif %}
  </div>
  <p class="govuk-body govuk-!-margin-bottom-0"></p>
{% endmacro %}
